{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Screen Assistant",
  "version": "0.1.0",
  "identifier": "com.localscreenassistant.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local Screen Assistant",
        "width": 1080,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

